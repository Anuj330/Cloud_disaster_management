APP_NAME=Cloud Disaster Management System
API_PREFIX=/api/v1
SECRET_KEY=replace-with-secure-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
ALLOW_INSECURE_DEV_DEFAULTS=true
BOOTSTRAP_INITIAL_ADMIN=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-admin-password

POSTGRES_USER=druser
POSTGRES_PASSWORD=drpass
POSTGRES_DB=drdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

CELERY_BROKER_DB=0
CELERY_BACKEND_DB=1

HEALTH_CHECK_TIMEOUT_SECONDS=2.0
HEALTH_CHECK_RETRY_COUNT=3
HEALTH_CHECK_RETRY_BACKOFF_SECONDS=0.5

CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=30

PRIMARY_REGION=region-a
SECONDARY_REGION=region-b
BACKUP_SCHEDULE_MINUTES=5
OBJECT_STORE_PATH=./object_store
MONITORING_ENABLED=true
MONITORING_INTERVAL_SECONDS=15
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
DB_WAIT_MAX_RETRIES=30
DB_WAIT_INTERVAL_SECONDS=2
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900
